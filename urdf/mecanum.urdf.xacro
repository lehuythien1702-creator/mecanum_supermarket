<?xml version="1.0"?>
<robot name="mecanum_assistant" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:property name="base_len" value="0.25"/>
  <xacro:property name="base_wid" value="0.20"/>
  <xacro:property name="base_h" value="0.02"/> <xacro:property name="wheel_r" value="0.05"/>
  <xacro:property name="wheel_l" value="0.04"/>
  <xacro:property name="clearance" value="0.04"/> <xacro:property name="pillar_r" value="0.008"/>
  <xacro:property name="pillar_h" value="0.12"/> <material name="aluminum">
    <color rgba="0.75 0.75 0.75 1.0"/>
  </material>

  <link name="base_footprint"/>
  
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_r}"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${clearance}"/>
      <geometry><box size="${base_len} ${base_wid} ${base_h}"/></geometry>
      <material name="aluminum"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${clearance}"/>
      <geometry><box size="${base_len} ${base_wid} ${base_h}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.02"/>
      <mass value="10.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.1"/>
    </inertial>
  </link>
  <gazebo reference="base_link"><material>Gazebo/Grey</material></gazebo>

  <xacro:macro name="pillar" params="prefix x_pos y_pos">
    <link name="pillar_${prefix}">
      <visual>
        <geometry><cylinder radius="${pillar_r}" length="${pillar_h}"/></geometry>
        <material name="aluminum"/>
      </visual>
      <collision>
        <geometry><cylinder radius="${pillar_r}" length="${pillar_h}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>
    <joint name="pillar_joint_${prefix}" type="fixed">
      <parent link="base_link"/>
      <child link="pillar_${prefix}"/>
      <origin xyz="${x_pos} ${y_pos} ${clearance + base_h/2 + pillar_h/2}"/>
    </joint>
  </xacro:macro>

  <xacro:pillar prefix="fl" x_pos="${base_len/2 - 0.02}" y_pos="${base_wid/2 - 0.02}"/>
  <xacro:pillar prefix="fr" x_pos="${base_len/2 - 0.02}" y_pos="-${base_wid/2 - 0.02}"/>
  <xacro:pillar prefix="rl" x_pos="-${base_len/2 - 0.02}" y_pos="${base_wid/2 - 0.02}"/>
  <xacro:pillar prefix="rr" x_pos="-${base_len/2 - 0.02}" y_pos="-${base_wid/2 - 0.02}"/>

  <link name="top_link">
    <visual>
      <geometry><box size="${base_len} ${base_wid} ${base_h}"/></geometry>
      <material name="aluminum"/>
    </visual>
    <collision>
      <geometry><box size="${base_len} ${base_wid} ${base_h}"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.02"/>
    </inertial>
  </link>
  <joint name="top_joint" type="fixed">
    <parent link="base_link"/>
    <child link="top_link"/>
    <origin xyz="0 0 ${clearance + base_h/2 + pillar_h + base_h/2}"/>
  </joint>
  <gazebo reference="top_link"><material>Gazebo/Grey</material></gazebo>

  <xacro:macro name="mecanum_wheel" params="prefix x_ref y_ref">
    <link name="${prefix}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_l}"/></geometry>
        <material name="dark"><color rgba="0.2 0.2 0.2 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="${wheel_r}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="${x_ref*(base_len/2 - 0.05)} ${y_ref*(base_wid/2 + wheel_l/2 + 0.005)} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1" friction="0.05"/>
    </joint>
    <gazebo reference="${prefix}_wheel">
      <material>Gazebo/DarkGrey</material>
      <mu1>0.0</mu1>
      <mu2>0.0</mu2>
    </gazebo>
  </xacro:macro>

  <xacro:mecanum_wheel prefix="front_left" x_ref="1" y_ref="1"/>
  <xacro:mecanum_wheel prefix="front_right" x_ref="1" y_ref="-1"/>
  <xacro:mecanum_wheel prefix="rear_left" x_ref="-1" y_ref="1"/>
  <xacro:mecanum_wheel prefix="rear_right" x_ref="-1" y_ref="-1"/>

  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.035" length="0.025"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.035" length="0.025"/></geometry>
    </collision>
    <inertial>
      <mass value="0.17"/> <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="top_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 ${base_h/2 + 0.0125}"/>
  </joint>

  <gazebo reference="lidar_link">
    <material>Gazebo/Black</material>
    <sensor name="lidar_sensor" type="ray">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="scan_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=scan</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <link name="camera_link">
    <visual>
      <geometry><box size="0.02 0.05 0.03"/></geometry>
      <material name="red"><color rgba="0.8 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.02 0.05 0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="top_link"/>
    <child link="camera_link"/>
    <origin xyz="${base_len/2} 0 ${base_h/2 + 0.015}"/>
  </joint>

  <gazebo reference="camera_link">
    <material>Gazebo/Red</material>
    <sensor type="camera" name="rgb_camera">
      <update_rate>30.0</update_rate>
      <camera>
        <horizontal_fov>1.047198</horizontal_fov> <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <ros><remapping>~/image_raw:=camera/image_raw</remapping></ros>
        <frame_name>camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="front_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="front_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rear_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rear_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(find mecanum_rl_description)/config/mecanum_ros2_control.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="omni_steering" filename="libgazebo_ros_planar_move.so">
      <ros>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <update_rate>50.0</update_rate>
      <publish_rate>50.0</publish_rate>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <covariance_x>0.0001</covariance_x>
      <covariance_y>0.0001</covariance_y>
      <covariance_yaw>0.01</covariance_yaw>
    </plugin>
  </gazebo>

</robot>