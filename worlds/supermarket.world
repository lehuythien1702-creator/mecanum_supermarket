    <!-- Kệ F: Hóa mỹ phẩm - Màu hồng - x=10, y=-3 -->
    <model name="shelf_F">
      <static>true</static>
      <pose>10 -3 0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry>
            <box>
              <size>4 0.4 1.5</size>
