            </box>
          </geometry>
          <material>
            <ambient>0.6 0 0.8 1</ambient>
            <diffuse>0.8 0.2 1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Kệ E: Đồ đông lạnh - Màu cam - x=10, y=1 -->
    <model name="shelf_E">
      <static>true</static>
      <pose>10 1 0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry>
            <box>
              <size>4 0.4 1.5</size>
