    <!-- Kệ D: Thịt cá - Màu tím - x=10, y=5 -->
    <model name="shelf_D">
      <static>true</static>
      <pose>10 5 0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry>
            <box>
              <size>4 0.4 1.5</size>
