    </model>

    <!-- ========== QUẦY THANH TOÁN ========== -->
    <!-- Quầy 1: x=16, y=3 -->
    <model name="checkout_1">
      <static>true</static>
      <pose>16 3 0 0 0 0</pose>
      <link name="link">
        <collision name="col">
