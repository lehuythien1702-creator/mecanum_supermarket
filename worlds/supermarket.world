<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="supermarket_world">
    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
      <gravity>0 0 -9.81</gravity>
    </physics>

    <!-- Mặt trời -->
    <include>
      <uri>model://sun</uri>
    </include>

    <!-- Mặt đất -->
    <include>
      <uri>model://ground_plane</uri>
    </include>

    <!-- Đèn chiếu sáng trên trần -->
    <light name='overhead_light_1' type='point'>
      <pose>7 2.5 3.5 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
      <attenuation>
        <range>20</range>
        <constant>0.3</constant>
        <linear>0.01</linear>
      </attenuation>
    </light>

    <light name='overhead_light_2' type='point'>
      <pose>7 -2.5 3.5 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
      <attenuation>
        <range>20</range>
        <constant>0.3</constant>
        <linear>0.01</linear>
      </attenuation>
    </light>

    <light name='overhead_light_3' type='point'>
      <pose>14 2.5 3.5 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
      <attenuation>
        <range>20</range>
        <constant>0.3</constant>
        <linear>0.01</linear>
      </attenuation>
    </light>

    <light name='overhead_light_4' type='point'>
      <pose>14 -2.5 3.5 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
      <attenuation>
        <range>20</range>
        <constant>0.3</constant>
        <linear>0.01</linear>
      </attenuation>
    </light>

    <!-- ========== TƯỜNG BAO QUANH 20x15m ========== -->
    <model name="supermarket_walls">
      <static>true</static>
      <link name="walls_link">
        <!-- Tường Bắc (North) - y=7.5 -->
        <collision name="wall_n_col">
          <pose>10 7.6 1.25 0 0 0</pose>
          <geometry>
            <box>
              <size>20 0.2 2.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="wall_n_vis">
          <pose>10 7.6 1.25 0 0 0</pose>
          <geometry>
            <box>
              <size>20 0.2 2.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.7 0.7 0.7 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
          </material>
        </visual>

        <!-- Tường Nam (South) - y=-7.5 -->
        <collision name="wall_s_col">
          <pose>10 -7.6 1.25 0 0 0</pose>
          <geometry>
            <box>
              <size>20 0.2 2.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="wall_s_vis">
          <pose>10 -7.6 1.25 0 0 0</pose>
          <geometry>
            <box>
              <size>20 0.2 2.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.7 0.7 0.7 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
          </material>
        </visual>

        <!-- Tường Đông (East) - x=20 -->
        <collision name="wall_e_col">
          <pose>20.1 0 1.25 0 0 0</pose>
          <geometry>
            <box>
              <size>0.2 15 2.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="wall_e_vis">
          <pose>20.1 0 1.25 0 0 0</pose>
          <geometry>
            <box>
              <size>0.2 15 2.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.7 0.7 0.7 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
          </material>
        </visual>

        <!-- Tường Tây (West) - x=0 -->
        <collision name="wall_w_col">
          <pose>-0.1 0 1.25 0 0 0</pose>
          <geometry>
            <box>
              <size>0.2 15 2.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="wall_w_vis">
          <pose>-0.1 0 1.25 0 0 0</pose>
          <geometry>
            <box>
              <size>0.2 15 2.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.7 0.7 0.7 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ========== 6 KỀ HÀNG ========== -->
    <!-- Kệ A: Sữa & Nước - Màu đỏ - x=4, y=5 -->
    <model name="shelf_A">
      <static>true</static>
      <pose>4 5 0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry>
            <box>
              <size>4 0.4 1.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="vis">
          <geometry>
            <box>
              <size>4 0.4 1.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.8 0 0 1</ambient>
            <diffuse>1 0.1 0.1 1</diffuse>
            <emissive>0 0 0 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- Kệ B: Bánh kẹo - Màu xanh - x=4, y=1 -->
    <model name="shelf_B">
      <static>true</static>
      <pose>4 1 0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry>
            <box>
