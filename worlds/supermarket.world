    <!-- ========== KHÁCH HÀNG (STATIC OBSTACLES) ========== -->
    <!-- Khách 1 -->
    <model name="customer_1">
      <static>true</static>
      <pose>6 3 0.4 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry>
            <cylinder>
              <radius>0.3</radius>
